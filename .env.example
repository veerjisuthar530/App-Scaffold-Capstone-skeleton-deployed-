# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.

# Public base URL used by server-side fetches (health check, etc).
# Locally: http://localhost:3000
# On Vercel: leave unset — VERCEL_URL is auto-provided and used as a fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Add future secrets below as NAME=placeholder, never with real values:
# DATABASE_URL=
# NEXT_PUBLIC_API_BASE=
